# Pflicht in Produktion (Vercel → Settings → Environment Variables)
DATABASE_URL=          # Neon Postgres (Storage → Create Database)
TOKEN_SECRET=          # mind. 32 Zeichen, z. B. openssl rand -base64 48
CRON_SECRET=           # mind. 16 Zeichen, schützt /api/cron/erinnerungen

# Empfohlen
NEXT_PUBLIC_APP_URL=https://stundenzettel-app-delta.vercel.app

# Optional: E-Mail-Erinnerungen (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Stundenzettel <noreply@deine-domain.de>
